{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git branch -D *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fx*)",
      "Bash(*--no-verify*)",
      "Bash(*--no-gpg-sign*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)"
    ],
    "allow": [
      "Read(//Users/tomohiro/Desktop/ClaudeCode/ITjujiryou/**)",
      "Edit(//Users/tomohiro/Desktop/ClaudeCode/ITjujiryou/**)",
      "Write(//Users/tomohiro/Desktop/ClaudeCode/ITjujiryou/**)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git fetch*)",
      "Bash(git add *)",
      "Bash(git rev-list*)",
      "Bash(git ls-tree*)",
      "Bash(git branch*)",
      "Bash(python3 scripts/dev_hooks/*)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(find . *)",
      "Bash(grep *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/scripts/dev_hooks/inject_phase.py"
          }
        ]
      }
    ]
  }
}
