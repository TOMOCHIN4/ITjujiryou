{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "mcp__itjujiryou__send_message",
      "mcp__itjujiryou__dispatch_task",
      "mcp__itjujiryou__consult_souther",
      "mcp__itjujiryou__propose_plan",
      "mcp__itjujiryou__evaluate_deliverable",
      "mcp__itjujiryou__update_status",
      "mcp__itjujiryou__read_status",
      "mcp__itjujiryou__deliver",
      "mcp__itjujiryou__record_thought",
      "Task",
      "Read",
      "Write(${CLAUDE_PROJECT_DIR}/../../outputs/**)",
      "Edit(${CLAUDE_PROJECT_DIR}/../../outputs/**)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(wc:*)"
    ],
    "deny": [
      "mcp__itjujiryou__consult_peer",
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__itjujiryou__deliver",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/../../.venv/bin/python ${CLAUDE_PROJECT_DIR}/../../scripts/hooks/check_persona_leak.py"
          }
        ]
      },
      {
        "matcher": "mcp__itjujiryou__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/../../.venv/bin/python ${CLAUDE_PROJECT_DIR}/../../scripts/hooks/check_persona_leak.py"
          }
        ]
      }
    ]
  }
}
