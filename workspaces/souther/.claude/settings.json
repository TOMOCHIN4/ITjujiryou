{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "mcp__itjujiryou__send_message",
      "mcp__itjujiryou__read_status",
      "Read"
    ],
    "deny": [
      "Bash",
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit",
      "WebSearch",
      "WebFetch",
      "TodoWrite",
      "mcp__itjujiryou__dispatch_task",
      "mcp__itjujiryou__deliver",
      "mcp__itjujiryou__evaluate_deliverable",
      "mcp__itjujiryou__propose_plan",
      "mcp__itjujiryou__consult_peer",
      "mcp__itjujiryou__consult_souther",
      "mcp__itjujiryou__update_status"
    ]
  },
  "model": "claude-opus-4-7",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/../../.venv/bin/python ${CLAUDE_PROJECT_DIR}/../../scripts/hooks/inject_souther_mode.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__itjujiryou__send_message",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/../../.venv/bin/python ${CLAUDE_PROJECT_DIR}/../../scripts/hooks/check_souther_recipient.py"
          }
        ]
      }
    ]
  }
}
